# Copy this file to .env and fill in your values
# NEVER commit .env to version control

DATABASE_URL=postgresql+asyncpg://securemsg:securemsg@db:5432/securemsg
REDIS_URL=redis://:yourpassword@redis:6379/0
REDIS_PASSWORD=your_redis_password_here
JWT_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_256_BIT_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Blockchain — set after deploying MessageDigestRegistry.sol to Sepolia
RPC_URL=https://rpc2.sepolia.org
PRIVATE_KEY=your_sepolia_wallet_private_key_here
CONTRACT_ADDRESS=your_deployed_contract_address_here
