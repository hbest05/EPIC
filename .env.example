# MessageDigestRegistry — environment variables for deployRegistry.js and the backend service.
# Copy this file to .env (never commit .env) and fill in your values.

# ---- Required ----

# JWT signing key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your_jwt_secret_here

# Redis password — must match REDIS_PASSWORD in both the api and redis service configs
REDIS_PASSWORD=your_redis_password_here

# ---- Blockchain (optional — leave blank to run without on-chain recording) ----

# Sepolia wallet private key used to deploy and call recordDigest() (0x-prefixed, 64 hex chars)
PRIVATE_KEY=your_sepolia_wallet_private_key_here

# Sepolia JSON-RPC endpoint — public endpoint below works without an API key
RPC_URL=https://rpc2.sepolia.org

# Populated automatically by node scripts/deployRegistry.js
# You can also set this manually after deployment if needed
CONTRACT_ADDRESS=populated_after_running_deploy_script
